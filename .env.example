# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=5432

# Google OAuth2
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URL=

# API server
API_ADDR=:8080
# Use "*" for open access (credentials not sent by browsers in wildcard mode).
# For authenticated flows (session cookies), set to your frontend origin:
# CORS_ALLOWED_ORIGINS=https://app.example.com
CORS_ALLOWED_ORIGINS=*
HTTP_READ_HEADER_TIMEOUT=10s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
